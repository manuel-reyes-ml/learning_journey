{
  // ---------------------------------------------------------------------------
  // OpenCode project config  ·  Manuel Reyes  ·  Stage 1 (roadmap v8.4)
  // Place at project root as `opencode.json` (or keep `.jsonc` for comments).
  // Docs verified: opencode.ai/docs/{providers,agents,commands,rules,config}
  //                (all pages last updated Jun 18–22, 2026)
  // ---------------------------------------------------------------------------
  "$schema": "https://opencode.ai/config.json",

  // === Default + small model =================================================
  // Primary agents use `model` unless they override it. `small_model` handles
  // session titles/summaries — pinned LOCAL so finance work never leaks to cloud.
  "model": "openrouter/minimax/minimax-m3",
  "small_model": "ollama/qwen3.5:9b",

  // === Providers =============================================================
  "provider": {
    // Local, free, private — your finance/proprietary default.
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": {
        // Key MUST match the Ollama tag exactly (run `ollama list`).
        "qwen3.5:9b": { "name": "Qwen3.5 9B (local)" }
      }
    },
    // OpenRouter is built-in — add the key once: /connect → OpenRouter → paste key
    // (stored in ~/.local/share/opencode/auth.json). Naming the slugs here just
    // makes them tidy to pick in /models and cycle with F2. Slugs are yours.
    "openrouter": {
      "models": {
        "minimax/minimax-m3":       { "name": "MiniMax M3 (build · default)" },
        "z-ai/glm-5.2":             { "name": "GLM-5.2 (build · alt)" },
        "qwen/qwen3.7-max":         { "name": "Qwen3.7 Max (build · alt)" },
        "deepseek/deepseek-v4-pro": { "name": "DeepSeek V4 Pro (plan · backup)" }
      }
    }
  },

  // === Built-in primary agents: your non-vibecode loop =======================
  "agent": {
    "plan": {
      // Default: fast/local planning. If the local 9B plans poorly, switch this
      // session via /models or F2, in order of preference:
      //   1) openrouter/z-ai/glm-5.2            (first fallback — runs clean in Plan)
      //   2) openrouter/deepseek/deepseek-v4-pro (last resort — can be slow / look
      //      frozen in Plan mode: reasoning-MoE + ai-sdk thinking-stream, not a hang)
      "model": "ollama/qwen3.5:9b",
      "permission": { "edit": "deny", "bash": "deny" }   // true read-only gate
    },
    "build": {
      // Default build model. If MiniMax struggles on a portion, switch this session
      // via /models or F2 to:  openrouter/z-ai/glm-5.2  or  openrouter/qwen/qwen3.7-max
      "model": "openrouter/minimax/minimax-m3",
      "permission": {
        "edit": "allow",              // looser: apply edits without a per-diff prompt
                                      // your gate is now the git-diff review + manual commit
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git add*": "allow",
          "make test": "allow",
          "make lint": "allow",
          "pytest*": "allow",
          "ruff*": "allow",
          "mypy*": "allow",
          "git commit*": "deny",      // you ALWAYS commit manually
          "git push*": "deny"
        }
      }
    }
  },

  // === Reuse your existing standards — DO NOT duplicate ======================
  // These .mdc rules are combined with AGENTS.md at session start, so OpenCode
  // inherits the same standards Cursor enforces. Single source of truth.
  "instructions": [
    ".cursor/rules/python-production-standards.mdc",
    ".cursor/rules/git-workflow.mdc",
    ".cursor/rules/learning-mode.mdc",
    ".cursor/rules/ai-sdk-patterns.mdc",
    ".cursor/rules/streamlit-patterns.mdc",
    ".cursor/rules/evaluation.mdc"
  ]
}
